    "sticky_notes": [
        {
            "id": "6f010000-6f00-4f00-8f00-6f0000010000",
            "position": [60.0, 40.0], "size": [1400.0, 50.0],
            "text": "WORKFLOW: Blender asset -> export FBX + Alembic + USD in a single headless session. Paths resolved from Prism product versions.",
            "color": "#200a20"
        },
        {
            "id": "6f020000-6f00-4f00-8f00-6f0000020000",
            "position": [500.0, 460.0], "size": [1360.0, 90.0],
            "text": "Three prism_get_export_path nodes resolve the versioned output paths from Prism products.\nChange 'identifier' values to match your pipeline product names (e.g. 'fbx_export', 'alembic_export', 'usd_export').\nVersion is empty = Prism creates the next version automatically.",
            "color": "#ffffcc"
        },
        {
            "id": "6f030000-6f00-4f00-8f00-6f0000030000",
            "position": [60.0, 760.0], "size": [1960.0, 50.0],
            "text": "Blender Action Chain: open .blend -> export FBX -> export Alembic -> export USD -> save versioned .blend -> run headless",
            "color": "#200a20"
        },
        {
            "id": "6f040000-6f00-4f00-8f00-6f0000040000",
            "position": [60.0, 1280.0], "size": [1360.0, 80.0],
            "text": "blender_get_action_result unpacks each export result by index position in the actions list:\nindex 1=FBX (action 0=open_blend), index 2=Alembic, index 3=USD, index 4=save_blend.\nThe 'path' output gives you the exported file path to verify or log.",
            "color": "#2a3a5a"
        }
    ],
